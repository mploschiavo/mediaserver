# media-dev environment template
# Copy this file to a local path and edit values.

PROFILE=full
NAMESPACE=media-dev
INGRESS_DOMAIN=media-dev.local
NODE_IP=192.168.1.60

# Safety default: keep namespace during rebuild/install.
DELETE_NAMESPACE=0
# Required alongside DELETE_NAMESPACE=1 for destructive teardown.
# DELETE_NAMESPACE_CONFIRM=media-dev

# Optional overrides:
# STORAGE_MODE=dynamic-pvc
# PVC_STORAGE_CLASS=
# INGRESS_CLASS=auto
# RUN_SMOKE_TEST=1
# GENERATE_SECRETS_ON_REBUILD=0
# PRESERVE_SECRET_ON_REBUILD=1
