# media-stack (default namespace) environment template
# Copy this file to a local path and edit values.

PROFILE=full
NAMESPACE=media-stack
INGRESS_DOMAIN=local
NODE_IP=192.168.1.60

# Safety default: keep namespace during rebuild/install.
DELETE_NAMESPACE=0

# Optional overrides:
# STORAGE_MODE=dynamic-pvc
# PVC_STORAGE_CLASS=
# INGRESS_CLASS=auto
# RUN_SMOKE_TEST=1
# GENERATE_SECRETS_ON_REBUILD=0
# PRESERVE_SECRET_ON_REBUILD=1
