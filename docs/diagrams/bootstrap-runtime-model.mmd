stateDiagram-v2
  [*] --> StartControllerServer
  StartControllerServer --> WaitForAction: serve mode (HTTP API on port 9100)
  StartControllerServer --> RunAction: auto-run / POST /actions/{name}

  WaitForAction --> RunAction: POST /actions/{name}
  RunAction --> WaitForAction

  state RunAction {
    [*] --> ResolveAction
    ResolveAction --> DispatchCore: core action
    ResolveAction --> DispatchJob: KNOWN_ACTIONS job (discovered from contracts)
    ResolveAction --> Rejected: name not in KNOWN_ACTIONS

    DispatchCore --> RunJobGraph
    DispatchJob --> RunJob

    state RunJobGraph {
      [*] --> LoadProfile
      LoadProfile --> ResolveBindings
      ResolveBindings --> BuildPlan: depends_on graph (per-service yaml + cross_cutting)
      BuildPlan --> RunPromises: probe then ensure (LifecycleHandlerAdapter)
      RunPromises --> [*]: 64 promises (49 agnostic / 14 k8s / 1 compose)
    }

    state RunJob {
      [*] --> ExecuteJobLifecycle
      ExecuteJobLifecycle --> [*]: probe / ensure / verify (ADR-0007)
    }

    DispatchCore --> ActionComplete
    DispatchJob --> ActionComplete
    Rejected --> ActionComplete
    ActionComplete --> [*]
  }

  RunAction --> FireWebhooks: post-action notifications
  FireWebhooks --> WaitForAction

  RunAction --> RetryableFailure: transient http / kube error
  RetryableFailure --> RunAction: retry decorator (capped backoff)
  RetryableFailure --> FatalFailure: max retries exceeded
  FatalFailure --> FireWebhooks

  note right of RunAction
    Source of truth for action names is
    KNOWN_ACTIONS in
    src/media_stack/api/services/known_actions.py
    (core actions + jobs + aliases from contracts).
  end note
