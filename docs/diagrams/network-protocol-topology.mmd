flowchart TD
  subgraph Z0["Zone 0: Clients + LAN (example 192.168.1.0/24)"]
    U["Users\nWeb / Mobile / TV"]
    DNS["LAN DNS + hosts overrides\n*.local"]
    FW["Router / Firewall / NAT"]
  end

  subgraph Z1["Zone 1: Kubernetes Edge (node IPs, e.g. 192.168.1.60)"]
    INGR["Ingress Controller\nTraefik/NGINX\n443/80 entrypoint"]
    HOSTS["Ingress host routes\nhomepage.local, jellyfin.local,\n*jellyseerr/arr/qb/sab*\nmaintainerr.local, tautulli.local"]
  end

  subgraph Z2["Zone 2: Service CIDR (example 10.152.183.0/24)"]
    S_UI["UI/API Services\nhomepage:3000 jellyfin:8096\njellyseerr:5055 maintainerr:6246\ntautulli:8181"]
    S_AUT["Automation Services\nsonarr:8989 radarr:7878\nlidarr:8686 readarr:8787\nbazarr:6767 prowlarr:9696"]
    S_DL["Download Services\nqbittorrent:8080 sabnzbd:8080\nflaresolverr:8191 unpackerr:5656"]
  end

  subgraph Z3["Zone 3: Pod CIDR (example 10.1.0.0/16)"]
    P_UI["UI Pods\nhomepage jellyfin jellyseerr"]
    P_AUT["Automation Pods\narr + bazarr + prowlarr"]
    P_DL["Downloader Pods\nqB sab flaresolverr unpackerr\ntautulli maintainerr"]
    P_JOB["Job/Cron Pods\nbootstrap prewarm hygiene indexers"]
  end

  subgraph Z4["Zone 4: Storage/Data Plane (PVC-backed)"]
    PVC_CFG["Config PVCs\nper app state"]
    PVC_DATA["Download PVCs\n/data/torrents + /data/usenet"]
    PVC_MEDIA["Media PVC\n/media/movies /tv /music /books"]
  end

  subgraph Z5["Zone 5: External Providers"]
    IDX["Indexers / Trackers / NZB"]
    META["Metadata + Subtitles\nTMDB TVDB OpenSubtitles"]
    IPTV["M3U + XMLTV feeds"]
    NTFY["Notification targets"]
  end

  LEG["Legend\nPod IPs are dynamic.\nService DNS and ports are stable.\nScaling changes replicas, not service contracts.\nCIDRs shown are examples."]

  U -->|HTTPS| DNS --> FW -->|443/80| INGR
  HOSTS -. hostname match .-> INGR

  INGR --> S_UI
  INGR --> S_AUT
  INGR --> S_DL

  S_UI --> P_UI
  S_AUT --> P_AUT
  S_DL --> P_DL

  P_AUT -->|HTTP API| S_DL
  P_AUT -->|HTTP API| S_AUT
  P_AUT -->|HTTP API| S_UI
  P_DL -->|HTTP API| S_AUT
  P_DL -->|HTTP API| S_UI
  P_JOB -->|API automation| S_UI
  P_JOB -->|API automation| S_AUT
  P_JOB -->|API automation| S_DL

  P_UI --> PVC_CFG
  P_AUT --> PVC_CFG
  P_DL --> PVC_CFG
  P_JOB --> PVC_CFG

  P_DL -->|downloads| PVC_DATA
  P_AUT -->|import/hardlink| PVC_DATA
  P_AUT -->|library mgmt| PVC_MEDIA
  P_UI -->|library read| PVC_MEDIA
  P_JOB -->|cleanup| PVC_DATA
  P_JOB -->|cleanup| PVC_MEDIA

  P_AUT --> IDX
  P_AUT --> META
  P_UI --> META
  P_UI --> IPTV
  P_JOB --> IPTV
  P_JOB --> NTFY
  P_UI --> NTFY

  LEG -. applies .- Z0
  LEG -. applies .- Z1
  LEG -. applies .- Z2
  LEG -. applies .- Z3
  LEG -. applies .- Z4
  LEG -. applies .- Z5
