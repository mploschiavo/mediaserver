__pycache__/
*.pyc
.coverage
.coverage.*

tests/e2e/playwright/node_modules/
tests/e2e/playwright/playwright-report/
tests/e2e/playwright/test-results/

secrets.generated.env
.state/
docker/.env
node_modules/
package.json
package-lock.json
# UI workspace MUST commit its own package + lockfile so CI / fresh clones can build
!ui/package.json
!ui/pnpm-lock.yaml
docker/config/
docker/data/
docker/media/
dist/config/
dist/data/
dist/media/
.gitignore
.claude/worktrees/
.claude/scheduled_tasks.lock
dist/VERSION
.env
# Anchor these to the repo root — without the leading slash they
# match any directory named `config/` / `data/` / `media/` anywhere in
# the tree, which silently shadows legitimate src/ packages (notably
# src/media_stack/api/services/config/ — the bare `config/` rule used
# to swallow new subpackages so they never landed in git).
/config/
/data/
/media/
dist/data/
dist/media/

# Templates baked into the controller image — must be tracked
!/config/defaults/
!/config/defaults/**

# Vitest scratch — vitest.config.ts.timestamp-<epoch>-<hash>.mjs leaks when a test run is interrupted
ui/*.timestamp-*.mjs
