__pycache__/
*.pyc
.coverage
.coverage.*

tests/e2e/playwright/node_modules/
tests/e2e/playwright/playwright-report/
tests/e2e/playwright/test-results/

secrets.generated.env
.state/
docker/.env
node_modules/
package.json
package-lock.json
# UI workspace MUST commit its own package + lockfile so CI / fresh clones can build
!ui/package.json
!ui/pnpm-lock.yaml
docker/config/
docker/data/
docker/media/
dist/config/
dist/data/
dist/media/
.gitignore
.claude/worktrees/
.claude/scheduled_tasks.lock
dist/VERSION
.env
# Anchor these to the repo root — without the leading slash they
# match any directory named `config/` / `data/` / `media/` anywhere in
# the tree, which silently shadows legitimate src/ packages (notably
# src/media_stack/api/services/config/ — the bare `config/` rule used
# to swallow new subpackages so they never landed in git).
/config/
/data/
/media/
dist/data/
dist/media/

# Templates baked into the controller image — must be tracked
!/config/defaults/
!/config/defaults/**

# Vitest scratch — vitest.config.ts.timestamp-<epoch>-<hash>.mjs leaks when a test run is interrupted
ui/*.timestamp-*.mjs

# Backup files. The 2026-05-12 incident root-caused to a captured
# ``GET /api/backup`` JSON committed as a fixture. The
# ``media-stack-backup-YYYYMMDD.json`` / ``media-stack-keys-
# backup.json`` filenames in the teardown how-to (``docs/how-to/
# teardown.md``) are the canonical names operators reach for; pre-
# ignore them at the repo root so a copy-paste from the doc
# doesn't accidentally commit live secrets. ``*.bak`` /
# ``*.backup`` cover the atomic-rename pattern used by the
# Authelia config writer, ``ProfileService.save``, etc. — those
# files contain pre-rotation copies of files we DO commit.
media-stack-backup-*.json
media-stack-keys-backup.json
*.bak
*.backup
