# Media Automation Stack — optional overrides.
#
# The compose file has sensible defaults for everything. This file is
# only needed if you want to override storage paths or credentials.
#
# Usage (no .env needed for defaults):
#   docker compose up -d
#   docker compose --profile standard up -d
#
# With overrides:
#   cp .env.example .env && edit .env
#   docker compose --profile standard up -d

# Storage paths (default: ./config, ./media, ./data relative to compose file)
# CONFIG_ROOT=/srv/media-stack/config
# MEDIA_ROOT=/srv/media-stack
# DATA_ROOT=/srv/media-stack/data

# Admin seed credentials (default: admin/admin).
# Used once on first boot to create the initial admin user. You're
# forced to rotate the password on first login — env value is NOT a
# persistent fallback. Must match k8s/secrets.example.yaml for
# compose↔K8s parity.
# STACK_ADMIN_USERNAME=admin
# STACK_ADMIN_PASSWORD=admin

# Timezone (default: UTC)
# TZ=America/Chicago
