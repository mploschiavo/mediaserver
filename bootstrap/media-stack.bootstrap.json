  "jellyfin_home_rails": {
    "enabled": false,
    "required": false,
    "cleanup_collections_when_disabled": true,
    "cleanup_collection_names": [
      "Trending",
      "Top Rated",
      "New This Week",
      "Because You Watched",
      "Trending TV",
      "Top Music",
      "Top Books"
    ],
    "url": "http://jellyfin:8096",
    "api_key_env": "JELLYFIN_API_KEY",
    "auto_discover_api_key_from_db": true,
    "api_key_db_path": "jellyfin/data/jellyfin.db",
    "api_key_name_preference": [
      "Jellyfin",
      "Jellyseerr"
    ],
    "auto_discover_user_id": true,
    "preferred_username_env": "STACK_ADMIN_USERNAME",
    "max_items_per_rail": 40,
    "rails": [
      {
        "name": "Trending",
        "path": "/Items",
        "query": {
          "includeItemTypes": "Movie",
          "recursive": "true",
          "sortBy": "PlayCount,DatePlayed",
          "sortOrder": "Descending"
        },
        "allowed_item_types": [
          "Movie"
        ],
        "limit": 40
      },
      {
        "name": "Top Rated",
        "path": "/Items",
        "query": {
          "includeItemTypes": "Movie",
          "recursive": "true",
          "sortBy": "CommunityRating,CriticRating",
          "sortOrder": "Descending",
          "minCommunityRating": "7"
        },
        "allowed_item_types": [
          "Movie"
        ],
        "limit": 40
      },
      {
        "name": "New This Week",
        "path": "/Items",
        "query": {
          "includeItemTypes": "Movie",
          "recursive": "true",
          "sortBy": "DateCreated,PremiereDate",
          "sortOrder": "Descending"
        },
        "allowed_item_types": [
          "Movie"
        ],
        "rolling_premiere_days": 7,
        "limit": 40
      },
      {
        "name": "Because You Watched",
        "path": "/Items/Suggestions",
        "query": {
          "mediaType": "Video",
          "type": "Movie"
        },
        "allowed_item_types": [
          "Movie"
        ],
        "fallback_query": {
          "path": "/Items",
          "query": {
            "includeItemTypes": "Movie",
            "recursive": "true",
            "isPlayed": "true",
            "sortBy": "DatePlayed,CommunityRating",
            "sortOrder": "Descending"
          }
        },
        "limit": 40
      },
      {
        "name": "Trending TV",
        "path": "/Items",
        "query": {
          "includeItemTypes": "Series",
          "recursive": "true",
          "sortBy": "PlayCount,DatePlayed,CommunityRating",
          "sortOrder": "Descending"
        },
        "allowed_item_types": [
          "Series"
        ],
        "limit": 40
      },
      {
        "name": "Top Music",
        "path": "/Items",
        "query": {
          "includeItemTypes": "MusicAlbum",
          "recursive": "true",
          "sortBy": "CommunityRating,PlayCount,DatePlayed",
          "sortOrder": "Descending"
        },
        "allowed_item_types": [
          "MusicAlbum"
        ],
        "limit": 30
      },
      {
        "name": "Top Books",
        "path": "/Items",
        "query": {
          "includeItemTypes": "Book",
          "recursive": "true",
          "sortBy": "CommunityRating,DateCreated",
          "sortOrder": "Descending"
        },
        "allowed_item_types": [
          "Book"
        ],
        "limit": 30
      }
    ]
  },
