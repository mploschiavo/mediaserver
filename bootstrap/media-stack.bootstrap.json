        {
          "host": "sabnzbd",
          "remote_path": "Downloads/complete",
          "local_path": "/data/usenet/completed"
        }
      ],
      "categories": {
        "Sonarr": "tv",
        "Radarr": "movies",
        "Lidarr": "music",
        "Readarr": "books"
      },
      "completed_paths": {
        "tv": "/data/usenet/completed/tv",
        "movies": "/data/usenet/completed/movies",
        "music": "/data/usenet/completed/music",
        "books": "/data/usenet/completed/books"
      }
    }
  },
  "app_auth": {
    "enabled": true,
    "method": "Forms",
    "required": "Enabled",
