      "api_key_config_path": "sabnzbd/sabnzbd.ini",
      "api_key_required": false,
      "remote_path_mappings": [
        {
          "host": "sabnzbd",
          "remote_path": "/config/Downloads/complete",
          "local_path": "/data/usenet/completed"
