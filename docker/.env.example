# Media Automation Stack — minimal configuration.
#
# Copy to .env and set the 3 required paths. All routing, hostnames, ports,
# and bootstrap settings come from the profile YAML (mounted into containers).
#
# Usage:
#   cp .env.example .env
#   # edit paths below
#   docker compose --profile bootstrap up -d

# === Required: host storage paths ===
CONFIG_ROOT=/srv/media-stack/config
MEDIA_ROOT=/srv/media-stack
DATA_ROOT=/srv/media-stack/data

# === Optional: override profile file (default: media-compose-standard.yaml) ===
# BOOTSTRAP_PROFILE_FILE=./examples/bootstrap-profiles/media-compose-standard.yaml

# === Optional: admin credentials (default: admin/media-stack) ===
# STACK_ADMIN_USERNAME=admin
# STACK_ADMIN_PASSWORD=media-stack

# === Optional: timezone and user (default: UTC / 1000:1000) ===
# TZ=America/Chicago
# PUID=1000
# PGID=1000
