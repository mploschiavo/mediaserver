# Exclude from production image build context
.git
.github
__pycache__
*.pyc
*.pyo
.pytest_cache
test-results
node_modules
.env
*.egg-info
.mypy_cache
.ruff_cache

# Runtime state — these directories balloon the build context to 30GB+ and
# serve no purpose at build time. docker/{config,data} and dist/{config,data}
# are bind-mount targets populated by running containers.
dist/config
dist/data
dist/media
docker/config
docker/data
docker/media
