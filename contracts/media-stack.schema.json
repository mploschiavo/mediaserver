{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media-stack.local/schemas/media-stack.bootstrap.schema.json",
  "title": "Media Stack Bootstrap Config",
  "type": "object",
  "required": [
    "config_version",
    "prowlarr_url",
    "arr_apps",
    "download_clients",
    "technology_bindings"
  ],
  "properties": {
    "config_version": {
      "type": "integer",
      "const": 2
    },
    "prowlarr_url": {
      "type": "string",
      "minLength": 1
    },
    "arr_apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "implementation",
          "url",
          "root_folder"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "implementation": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "root_folder": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "download_clients": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "url",
          "host",
          "port",
          "name",
          "implementation"
        ],
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "host": {
            "type": "string",
            "minLength": 1
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "implementation": {
            "type": "string",
            "minLength": 1
          },
          "queue_guardrails": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "technology_bindings": {
      "type": "object",
      "required": [
        "media_server"
      ],
      "properties": {
        "torrent_client": {
          "type": "string",
          "minLength": 1
        },
        "usenet_client": {
          "type": "string",
          "minLength": 1
        },
        "media_server": {
          "type": "string",
          "minLength": 1
        },
        "request_manager": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "arr_quality_upgrade": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "allow_upgrades": {
          "type": "boolean"
        },
        "disallow_quality_name_tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cutoff_preferred_name_tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "by_app": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "app_auth": {
      "type": "object",
      "additionalProperties": true
    },
    "arr_discovery_lists": {
      "type": "object",
      "additionalProperties": true
    },
    "arr_download_handling": {
      "type": "object",
      "additionalProperties": true
    },
    "arr_media_management": {
      "type": "object",
      "additionalProperties": true
    },
    "arr_indexer_sync": {
      "type": "object",
      "additionalProperties": true
    },
    "disk_guardrails": {
      "type": "object",
      "additionalProperties": true
    },
    "jellyfin_prewarm": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "url": {
          "type": "string"
        },
        "refresh_library": {
          "type": "boolean"
        },
        "refresh_channels": {
          "type": "boolean"
        },
        "refresh_guide": {
          "type": "boolean"
        },
        "book_sidecar_artwork": {
          "type": "object"
        },
        "music_sidecar_artwork": {
          "type": "object"
        },
        "metadata_backfill": {
          "type": "object"
        },
        "artwork_health_check": {
          "type": "object"
        },
        "library_refresh_query": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "jellyfin_livetv": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "refresh_on_bootstrap": {
          "type": "boolean"
        },
        "cleanup_duplicates": {
          "type": "boolean"
        },
        "recreate_managed_guides": {
          "type": "boolean"
        },
        "prune_unmanaged_tuners": {
          "type": "boolean"
        },
        "prune_unmanaged_guides": {
          "type": "boolean"
        },
        "fallback_enable_all_tuners_when_mapping_missing": {
          "type": "boolean"
        },
        "url": {
          "type": "string"
        },
        "tuners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "normalize_tvg_id_suffix": {
                "type": "boolean"
              },
              "filter_to_guide_channels": {
                "type": "boolean"
              },
              "filter_guide_path": {
                "type": "string"
              },
              "materialized_output_path": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "guides": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "media_hygiene": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "cleanup_arr_failed_queue": {
          "type": "boolean"
        },
        "arr_failed_queue_cleanup": {
          "type": "object"
        },
        "qbit_ipfilter": {
          "type": "object"
        },
        "filesystem": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "maintainerr": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "url": {
          "type": "string"
        },
        "integrations": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "required": {
              "type": "boolean"
            },
            "test_connections": {
              "type": "boolean"
            },
            "main": {
              "type": "object"
            },
            "radarr": {
              "type": "object"
            },
            "sonarr": {
              "type": "object"
            },
            "jellyseerr": {
              "type": "object"
            },
            "tautulli": {
              "type": "object"
            }
          },
          "additionalProperties": true
        },
        "policy_relative_path": {
          "type": "string"
        },
        "rules_library": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "include_defaults": {
              "type": "boolean"
            },
            "relative_path": {
              "type": "string"
            },
            "merge_mode": {
              "type": "string",
              "enum": [
                "append",
                "replace"
              ]
            },
            "enabled_files": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "policy": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "jellyseerr": {
      "type": "object",
      "additionalProperties": true
    },
    "bazarr": {
      "type": "object",
      "additionalProperties": true
    },
    "homepage": {
      "type": "object",
      "additionalProperties": true
    },
    "jellyfin_libraries": {
      "type": "object",
      "additionalProperties": true
    },
    "jellyfin_plugins": {
      "type": "object",
      "additionalProperties": true
    },
    "jellyfin_playback": {
      "type": "object",
      "additionalProperties": true
    },
    "jellyfin_home_rails": {
      "type": "object",
      "additionalProperties": true
    },
    "jellyfin_auto_collections": {
      "type": "object",
      "additionalProperties": true
    },
    "quality_profiles": {
      "type": "object",
      "additionalProperties": true
    },
    "readarr": {
      "type": "object",
      "additionalProperties": true
    },
    "sonarr_seed_series": {
      "type": "object",
      "additionalProperties": true
    },
    "prowlarr_indexers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "prowlarr_auto_add_tested_indexers": {
      "type": "boolean"
    },
    "prowlarr_auto_indexer_exclude_name_tokens": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prowlarr_indexer_reputation": {
      "type": "object",
      "additionalProperties": true
    },
    "refresh_health_after_bootstrap": {
      "type": "boolean"
    },
    "trigger_indexer_sync": {
      "type": "boolean"
    },
    "media_server": {
      "type": "object",
      "additionalProperties": true
    },
    "config_overlays": {
      "type": "object",
      "additionalProperties": true
    },
    "flaresolverr": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "url": {
          "type": "string"
        },
        "proxy_name": {
          "type": "string"
        },
        "request_timeout_seconds": {
          "type": "integer"
        },
        "test_connection": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      },
      "additionalProperties": true
    },
    "adapter_hooks": {
      "type": "object",
      "properties": {
        "event_handlers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "operation_handlers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "runner_event_plans": {
          "type": "object"
        },
        "runner_operation_plans": {
          "type": "object"
        },
        "media_server_event_plans": {
          "type": "object"
        },
        "media_server_operation_plans": {
          "type": "object"
        },
        "runner_phase_scripts": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "bootstrap_all": {
          "type": "object",
          "required": [
            "phase_plan",
            "components"
          ],
          "properties": {
            "enable_components": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "components": {
              "type": "object",
              "additionalProperties": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "binding": {
                        "type": "string",
                        "minLength": 1
                      },
                      "technology": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "phase_plan": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "object",
                    "required": [
                      "operation"
                    ],
                    "properties": {
                      "operation": {
                        "type": "string",
                        "minLength": 1
                      },
                      "skip_flag": {
                        "type": "string",
                        "minLength": 1
                      },
                      "phase_name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "enabled": {
                        "type": "boolean"
                      },
                      "params": {
                        "type": "object",
                        "additionalProperties": true
                      },
                      "when": {
                        "oneOf": [
                          {
                            "type": "boolean"
                          },
                          {
                            "type": "object"
                          },
                          {
                            "type": "array"
                          }
                        ]
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "component_manifests": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "component_deployments": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "bootstrap_job": {
          "type": "object",
          "required": [
            "phase_plan",
            "components"
          ],
          "properties": {
            "components": {
              "type": "object",
              "additionalProperties": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "binding": {
                        "type": "string",
                        "minLength": 1
                      },
                      "technology": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "phase_plan": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "object",
                    "required": [
                      "operation"
                    ],
                    "properties": {
                      "operation": {
                        "type": "string",
                        "minLength": 1
                      },
                      "skip_flag": {
                        "type": "string",
                        "minLength": 1
                      },
                      "phase_name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "enabled": {
                        "type": "boolean"
                      },
                      "params": {
                        "type": "object",
                        "additionalProperties": true
                      },
                      "when": {
                        "oneOf": [
                          {
                            "type": "boolean"
                          },
                          {
                            "type": "object"
                          },
                          {
                            "type": "array"
                          }
                        ]
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "supports_phase_bindings": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": true
        },
        "skip_flag_aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "options": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env_vars": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "scale_policy": {
          "type": "object",
          "required": [
            "apps"
          ],
          "properties": {
            "apps": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "scale_to_zero_apps": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "rebuild": {
          "type": "object",
          "properties": {
            "preserve_secret_keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "profile_manifest_paths": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "component_enable_manifest_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "profile_scale_to_zero_apps": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "profile_tls": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "secret_name": {
                    "type": "string"
                  },
                  "hosts": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "edge": {
          "type": "object",
          "additionalProperties": true
        },
        "microk8s_reconcile": {
          "type": "object",
          "required": [
            "phase_plan",
            "optional_deployments",
            "optional_manifest_paths"
          ],
          "properties": {
            "phase_plan": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "event",
                  "handler"
                ],
                "properties": {
                  "phase_name": {
                    "type": "string"
                  },
                  "event": {
                    "type": "string"
                  },
                  "handler": {
                    "type": "string"
                  },
                  "enabled": {
                    "type": "boolean"
                  },
                  "when": {
                    "oneOf": [
                      {
                        "type": "boolean"
                      },
                      {
                        "type": "object"
                      },
                      {
                        "type": "array"
                      }
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "optional_deployments": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "optional_manifest_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "conditional_manifests": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "deployment",
                  "manifest_path"
                ],
                "properties": {
                  "deployment": {
                    "type": "string"
                  },
                  "manifest_path": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "container_preflight_handlers": {
      "type": "array",
      "description": "Declarative preflight handlers run inside the bootstrap runner container before the main pipeline.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "handler": {
            "type": "string",
            "description": "module.path:function_name"
          },
          "args": {
            "type": "object"
          },
          "export_env": {
            "type": "boolean"
          },
          "optional": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "handler"
        ]
      }
    },
    "container_post_bootstrap_handlers": {
      "type": "array",
      "description": "Declarative post-bootstrap handlers run after the main pipeline completes.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "handler": {
            "type": "string",
            "description": "module.path:function_name"
          },
          "args": {
            "type": "object"
          },
          "optional": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "handler"
        ]
      }
    }
  },
  "additionalProperties": false
}
