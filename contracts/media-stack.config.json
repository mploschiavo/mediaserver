    },
    "policy": {
      "retention": {
        "max_disk_used_percent": 65,
        "target_disk_used_percent": 58,
        "protect_recently_added_days": 21,
        "protect_unwatched_days": 30
      }
    },
    "default_policy": {
      "version": 1,
      "retention": {
        "max_disk_used_percent": 65,
        "target_disk_used_percent": 58,
        "protect_recently_added_days": 21,
        "protect_unwatched_days": 30,
        "minimum_rating_to_keep": 6.5
      },
      "rules": []
    }
  },
  "adapter_hooks": {
    "jellyfin": {
      "prewarm_mode": {
        "complete_message": "[OK] Jellyfin prewarm mode complete.",
        "steps": [
          {
            "event": "ENSURE",
            "handler": "ensure_jellyfin_prewarm",
            "args": [
              "cfg",
              "config_root",
              "wait_timeout"
            ]
          }
        ]
      },
      "home_rails_mode": {
        "complete_message": "[OK] Jellyfin home rails mode complete.",
        "steps": [
          {
            "event": "ENSURE",
            "handler": "ensure_jellyfin_home_rails",
            "args": [
              "cfg",
              "config_root",
              "wait_timeout"
            ]
          }
        ]
      },
      "post_servarr_pre_hygiene_steps": {
        "parallel": true,
        "steps": [
          {
            "event": "ENSURE",
            "handler": "ensure_jellyfin_livetv",
            "args": [
              "cfg",
              "config_root",
              "wait_timeout"
            ],
            "enabled_attr": "configure_media_server_livetv",
            "required_attr": "jellyfin_livetv_required",
            "warning_message": "[WARN] Jellyfin Live TV: automation skipped. Set jellyfin_livetv.required=true to fail the bootstrap instead."
          },
          {
            "event": "ENSURE",
            "handler": "ensure_jellyfin_libraries",
            "args": [
              "cfg",
              "config_root",
              "wait_timeout"
            ],
            "enabled_attr": "configure_media_server_libraries",
            "required_attr": "jellyfin_libraries_required",
            "warning_message": "[WARN] Jellyfin libraries: automation skipped. Set jellyfin_libraries.required=true to fail the bootstrap instead."
          },
          {
            "event": "ENSURE",
            "handler": "ensure_jellyfin_plugins",
            "args": [
              "cfg",
