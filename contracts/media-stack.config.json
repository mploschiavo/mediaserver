  "maintainerr": {
    "enabled": true,
    "required": false,
    "url": "http://maintainerr:6246",
    "integrations": {
      "enabled": true,
      "required": false,
      "test_connections": true,
      "main": {
        "enabled": true,
        "media_server_type": "jellyfin",
