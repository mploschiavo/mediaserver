{
  "config_version": 2,
  "trigger_indexer_sync": true,
  "refresh_health_after_setup": true,
  "adapter_hooks": {
    "event_handlers": {
      "VALIDATE": {
        "ensure_app_auth_settings": "media_stack.services.apps.servarr.runtime.arr_ops:ensure_app_auth_settings"
      },
      "RUN": {
        "run_servarr_pipeline": "media_stack.services.apps.servarr.runtime_ops:run_servarr_pipeline",
        "run_media_hygiene": "media_stack.services.apps.servarr.runtime.hygiene_ops:run_media_hygiene"
      },
      "ENSURE": {
        "enforce_disk_guardrails": "media_stack.services.apps.servarr.runtime.hygiene_ops:enforce_disk_guardrails"
      }
    },
    "edge": {
      "router_provider": "envoy",
      "router_service_names_by_provider": {
        "traefik": [
          "traefik"
        ],
        "envoy": [
          "envoy"
        ]
      },
      "media_server_service_names": [
        "jellyfin",
        "jellyfin-nvidia"
      ],
      "ingress_class_priority": [
        "public",
        "nginx"
      ],
      "compose_provider_specs": {
        "traefik": {
          "enable_label_key": "traefik.enable",
          "router_label_prefix": "traefik.http.routers.",
          "service_label_prefix": "traefik.http.services.",
          "middleware_label_prefix": "traefik.http.middlewares.",
          "router_rule_key_template": "traefik.http.routers.{router_name}.rule",
          "router_service_key_template": "traefik.http.routers.{router_name}.service",
          "router_middleware_key_template": "traefik.http.routers.{router_name}.middlewares",
          "strip_prefix_key_template": "traefik.http.middlewares.{middleware_name}.stripprefix.prefixes",
          "path_rule_template": "Host(`{gateway_host}`) && PathPrefix(`{path_prefix}`)",
          "redirect_regex_key_template": "traefik.http.middlewares.{middleware_name}.redirectregex.regex",
          "redirect_replacement_key_template": "traefik.http.middlewares.{middleware_name}.redirectregex.replacement",
          "redirect_permanent_key_template": "traefik.http.middlewares.{middleware_name}.redirectregex.permanent",
          "path_redirect_regex_template": "^https?://[^/:]+(:[0-9]+)?{path_prefix_regex}/?(.*)",
          "path_redirect_replacement_template": "{scheme}://{redirect_host}$1/$2",
          "media_server_rule_key_template": "traefik.http.routers.{service_name}.rule",
          "direct_host_rule_template": "Host(`{direct_host}`)"
        },
        "envoy": {
          "enable_label_key": "traefik.enable",
          "router_label_prefix": "traefik.http.routers.",
          "service_label_prefix": "traefik.http.services.",
          "middleware_label_prefix": "traefik.http.middlewares.",
          "router_rule_key_template": "traefik.http.routers.{router_name}.rule",
          "router_service_key_template": "traefik.http.routers.{router_name}.service",
          "router_middleware_key_template": "traefik.http.routers.{router_name}.middlewares",
          "strip_prefix_key_template": "traefik.http.middlewares.{middleware_name}.stripprefix.prefixes",
          "path_rule_template": "Host(`{gateway_host}`) && PathPrefix(`{path_prefix}`)",
          "media_server_rule_key_template": "traefik.http.routers.{service_name}.rule",
          "direct_host_rule_template": "Host(`{direct_host}`)"
        }
      }
    },
    "skip_flag_aliases": {
      "skip_torrent_client_ensure": {
        "options": [
          "--skip-qbit-ensure"
        ],
        "env_vars": [
          "SKIP_QBIT_ENSURE"
        ]
      },
      "skip_usenet_client_ensure": {
        "options": [
          "--skip-sab-ensure"
        ],
        "env_vars": [
          "SKIP_SAB_ENSURE"
        ]
      },
      "skip_media_server_bootstrap": {
        "options": [
          "--skip-jellyfin-bootstrap"
        ],
        "env_vars": [
          "SKIP_JELLYFIN_BOOTSTRAP"
        ]
      }
    },
    "runner_phase_scripts": {
      "torrent_client_credentials": {
        "qbittorrent": "media_stack.services.apps.qbittorrent.cli.ensure_qbit_credentials_main"
      },
      "usenet_client_api_access": {
        "sabnzbd": "media_stack.services.apps.sabnzbd.cli.ensure_sabnzbd_api_access_main"
      },
      "media_server_bootstrap": {
        "jellyfin": "media_stack.services.apps.jellyfin.cli.ensure_jellyfin_controller_main"
      },
      "request_manager_seed_local_admin": {
        "jellyseerr": "media_stack.services.apps.jellyseerr.cli.seed_jellyseerr_local_admin_main"
      },
      "component_key_sync": {
        "unpackerr": "media_stack.services.apps.unpackerr.cli.sync_unpackerr_keys_main"
      }
    },
    "bootstrap_all": {
      "phase_plan": [
        {
          "operation": "run",
          "phase_name": "Ensure torrent client bootstrap access ({component|unbound})",
          "skip_flag": "skip_torrent_client_ensure",
          "when": {
            "all_of": [
              {
                "any_of": [
                  {
                    "var": "components.torrent_client.selected.configure_arr_clients",
                    "truthy": true
                  },
                  {
                    "var": "components.torrent_client.selected.set_categories_in_qbit",
                    "truthy": true
                  },
                  {
                    "var": "components.torrent_client.selected.set_categories",
                    "truthy": true
                  }
                ]
              },
              {
                "var": "components.torrent_client.scripts.torrent_client_credentials",
                "truthy": true
              }
            ]
          },
          "params": {
            "action": "component_script",
            "component": "torrent_client",
            "script_phase": "torrent_client_credentials",
            "env": {
              "NAMESPACE": "$namespace",
              "PREPARE_HOST_ROOT": "$prepare_host_root"
            }
          }
        },
        {
          "operation": "run",
          "phase_name": "Ensure media server bootstrap access ({component|unbound})",
          "skip_flag": "skip_media_server_bootstrap",
          "when": {
            "var": "components.media_server.scripts.media_server_bootstrap",
            "truthy": true
          },
          "params": {
            "action": "component_script",
            "component": "media_server",
            "script_phase": "media_server_bootstrap",
            "env": {
              "NAMESPACE": "$namespace",
              "SECRET_NAME": "$secret_name"
            }
          }
        },
        {
          "operation": "run",
          "phase_name": "Ensure usenet client API access ({component|unbound})",
          "skip_flag": "skip_usenet_client_ensure",
          "when": {
            "all_of": [
              {
                "var": "components.usenet_client.selected.configure_arr_clients",
                "truthy": true
              },
              {
                "var": "components.usenet_client.scripts.usenet_client_api_access",
                "truthy": true
              }
            ]
          },
          "params": {
            "action": "component_script",
            "component": "usenet_client",
            "script_phase": "usenet_client_api_access",
            "env": {
              "NAMESPACE": "$namespace"
            }
          }
        },
        {
          "operation": "run",
          "phase_name": "Run bootstrap job",
          "params": {
            "action": "script",
            "script": "media_stack.cli.commands.run_controller_job_main",
            "args": [
              "$config_file"
            ],
            "env": {
              "NAMESPACE": "$namespace",
              "SKIP_TORRENT_CLIENT_ENSURE": "1",
              "SKIP_USENET_CLIENT_ENSURE": "1",
              "PREPARE_HOST_ROOT": "$prepare_host_root"
            }
          }
        },
        {
          "operation": "run",
          "phase_name": "Seed request manager local admin ({component|unbound})",
          "when": {
            "var": "components.request_manager.scripts.request_manager_seed_local_admin",
            "truthy": true
          },
          "params": {
            "action": "component_script",
            "component": "request_manager",
            "script_phase": "request_manager_seed_local_admin",
            "env": {
              "NAMESPACE": "$namespace"
            }
          }
        },
        {
          "operation": "run",
          "phase_name": "Run indexer auto-discovery (prowlarr)",
          "when": {
            "var": "config.prowlarr_url",
            "truthy": true
          },
          "params": {
            "action": "http_action",
            "service_name": "bootstrap",
            "service_port": 9100,
            "action_name": "auto-indexers",
            "namespace_var": "$namespace"
          }
        },
        {
          "operation": "run",
          "when": {
            "var": "flags.enable_components",
            "equals": true
          },
          "params": {
            "action": "enable_components"
          }
        }
      ],
      "components": {
        "torrent_client": {
          "binding": "torrent_client"
        },
        "media_server": {
          "binding": "media_server"
        },
        "usenet_client": {
          "binding": "usenet_client"
        },
        "request_manager": {
          "binding": "request_manager"
        },
        "indexer_manager": {
          "technology": "prowlarr"
        }
      },
      "enable_components": [
        "unpackerr"
      ],
      "component_manifests": {
        "unpackerr": "k8s/unpackerr.yaml"
      },
      "component_deployments": {
        "unpackerr": "unpackerr"
      }
    },
    "bootstrap_job": {
      "components": {
        "torrent_client": {
          "binding": "torrent_client"
        },
        "usenet_client": {
          "binding": "usenet_client"
        },
        "request_manager": {
          "binding": "request_manager"
        }
      },
      "call_handlers": {
        "activate_media_server_plugins": "media_stack.services.apps.jellyfin.cli.controller_hooks:activate_media_server_plugins"
      },
      "runtime_config_policy_handler": "media_stack.services.apps.stack.controller_config_policy:apply_bootstrap_runtime_policy",
      "compose_preflight_handlers": [
        "media_stack.services.apps.stack.compose_preflight:ensure_compose_stack_filesystem_paths",
        "media_stack.services.apps.jellyfin.compose_preflight:ensure_compose_jellyfin_bootstrap_access",
        "media_stack.services.apps.sabnzbd.compose_preflight:ensure_compose_sabnzbd_api_access",
        "media_stack.services.apps.qbittorrent.compose_preflight:ensure_compose_torrent_client_credentials"
      ],
      "secret_priming_targets": {
        "usenet_client": {
          "env_key": "SABNZBD_API_KEY",
          "env_var": "SABNZBD_API_KEY",
          "deployment": "sabnzbd",
          "extract_command": "sed -n 's/^[[:space:]]*api_key[[:space:]]*=[[:space:]]*//p' /config/sabnzbd.ini | head -n1"
        },
        "request_manager": {
          "env_key": "JELLYSEERR_API_KEY",
          "env_var": "JELLYSEERR_API_KEY",
          "deployment": "jellyseerr",
          "extract_command": "node -e \"const fs=require('fs'); const d=JSON.parse(fs.readFileSync('/app/config/settings.json','utf8')); process.stdout.write(String(((d.main||{}).apiKey||'')).trim());\""
        },
        "media_server_api_key": {
          "env_key": "JELLYFIN_API_KEY",
          "env_var": "JELLYFIN_API_KEY",
          "deployment": "jellyseerr",
          "extract_command": "node -e \"const fs=require('fs'); const d=JSON.parse(fs.readFileSync('/app/config/settings.json','utf8')); process.stdout.write(String((((d.jellyfin||{}).apiKey)||'')).trim());\""
        },
        "media_server_user_id": {
          "env_key": "JELLYFIN_USER_ID",
          "env_var": "JELLYFIN_USER_ID",
          "deployment": "jellyseerr",
          "extract_command": "node -e \"const fs=require('fs'); const http=require('http'); const d=JSON.parse(fs.readFileSync('/app/config/settings.json','utf8')); const apiKey=String((((d.jellyfin||{}).apiKey)||'')).trim(); if(!apiKey){process.exit(0)} http.get('http://jellyfin:8096/Users?api_key='+encodeURIComponent(apiKey),(res)=>{let body=''; res.on('data',(chunk)=>body+=chunk); res.on('end',()=>{try{const users=JSON.parse(body); const list=Array.isArray(users)?users:[]; const user=list.find((item)=>String(item&&item.Name||'').trim().toLowerCase()==='admin') || list.find((item)=>Boolean(item&&item.Policy&&item.Policy.IsAdministrator)); process.stdout.write(String(user&&user.Id||'').trim());}catch(_err){}});}).on('error',()=>{});\""
        },
        "analytics": {
          "env_key": "TAUTULLI_API_KEY",
          "env_var": "TAUTULLI_API_KEY",
          "deployment": "tautulli",
          "extract_command": "sed -n 's/^[[:space:]]*api_key[[:space:]]*=[[:space:]]*//p' /config/config.ini | head -n1"
        }
      },
      "post_job_actions": [
        {
          "marker": "Jellyseerr: settings file bootstrap applied",
          "phase_name": "Restart request manager after file bootstrap",
          "deployment": "jellyseerr",
          "restart_if_exists": false,
          "timeout_seconds": 180
        },
        {
          "marker": "Homepage: wrote services config",
          "phase_name": "Restart homepage after config sync",
          "deployment": "homepage",
          "restart_if_exists": true,
          "timeout_seconds": 180
        },
        {
          "marker": "Bazarr: wrote integration config",
          "phase_name": "Restart subtitle manager after config sync",
          "deployment": "bazarr",
          "restart_if_exists": true,
          "timeout_seconds": 180
        }
      ],
      "phase_plan": [
        {
          "operation": "run_component_script",
          "phase_name": "Ensure torrent client bootstrap access ({component|unbound})",
          "skip_flag": "skip_torrent_client_ensure",
          "when": {
            "all_of": [
              {
                "any_of": [
                  {
                    "var": "components.torrent_client.selected.configure_arr_clients",
                    "truthy": true
                  },
                  {
                    "var": "components.torrent_client.selected.set_categories_in_qbit",
                    "truthy": true
                  },
                  {
                    "var": "components.torrent_client.selected.set_categories",
                    "truthy": true
                  }
                ]
              },
              {
                "var": "components.torrent_client.scripts.torrent_client_credentials",
                "truthy": true
              }
            ]
          },
          "params": {
            "component": "torrent_client",
            "binding": "torrent_client",
            "script_phase": "torrent_client_credentials",
            "env": {
              "NAMESPACE": "$namespace",
              "PREPARE_HOST_ROOT": "$prepare_host_root"
            }
          }
        },
        {
          "operation": "run_component_script",
          "phase_name": "Ensure usenet client API access ({component|unbound})",
          "skip_flag": "skip_usenet_client_ensure",
          "when": {
            "all_of": [
              {
                "var": "components.usenet_client.selected.configure_arr_clients",
                "truthy": true
              },
              {
                "var": "components.usenet_client.scripts.usenet_client_api_access",
                "truthy": true
              }
            ]
          },
          "params": {
            "component": "usenet_client",
            "binding": "usenet_client",
            "script_phase": "usenet_client_api_access",
            "env": {
              "NAMESPACE": "$namespace"
            }
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Prepare bootstrap job config",
          "params": {
            "handler": "prepare_bootstrap_job_config"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Ensure bootstrap PVC prerequisites",
          "params": {
            "handler": "ensure_bootstrap_pvc_prereqs"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Prime Arr API keys into secret",
          "params": {
            "handler": "prime_servarr_api_keys_secret"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Prime usenet client API key into secret ({component|unbound})",
          "when": {
            "var": "bindings.usenet_client",
            "in": [
              "sabnzbd"
            ]
          },
          "params": {
            "handler": "prime_usenet_client_api_key_secret",
            "component": "usenet_client",
            "binding": "usenet_client"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Prime request manager API key into secret ({component|unbound})",
          "when": {
            "var": "bindings.request_manager",
            "in": [
              "jellyseerr"
            ]
          },
          "params": {
            "handler": "prime_request_manager_api_key_secret",
            "component": "request_manager",
            "binding": "request_manager"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Prime analytics API key into secret",
          "when": {
            "var": "config.maintainerr.integrations.tautulli.enabled",
            "truthy": true
          },
          "params": {
            "handler": "prime_analytics_api_key_secret"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Update bootstrap ConfigMaps",
          "params": {
            "handler": "update_bootstrap_configmaps"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Ensure bootstrap Deployment",
          "params": {
            "handler": "ensure_bootstrap_deployment"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Wait for bootstrap service",
          "params": {
            "handler": "wait_for_bootstrap_service"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Prime media server API key into secret ({component|unbound})",
          "when": {
            "var": "bindings.media_server",
            "in": [
              "jellyfin"
            ]
          },
          "params": {
            "handler": "prime_media_server_api_key_secret",
            "component": "media_server",
            "binding": "media_server"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Prime media server user id into secret ({component|unbound})",
          "when": {
            "var": "bindings.media_server",
            "in": [
              "jellyfin"
            ]
          },
          "params": {
            "handler": "prime_media_server_user_id_secret",
            "component": "media_server",
            "binding": "media_server"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Print bootstrap Job logs",
          "params": {
            "handler": "print_bootstrap_job_logs"
          }
        },
        {
          "operation": "call_handler",
          "phase_name": "Activate media server plugins ({component|unbound})",
          "when": {
            "all_of": [
              {
                "var": "config.adapter_hooks.bootstrap_job.call_handlers.activate_media_server_plugins",
                "truthy": true
              },
              {
                "var": "bindings.media_server",
                "in": [
                  "jellyfin"
                ]
              }
            ]
          },
          "params": {
            "handler": "activate_media_server_plugins",
            "component": "media_server",
            "binding": "media_server"
          }
        }
      ]
    },
    "rebuild": {
      "preserve_secret_keys": [
        "STACK_ADMIN_USERNAME",
        "STACK_ADMIN_PASSWORD",
        "SABNZBD_API_KEY",
        "JELLYFIN_API_KEY",
        "JELLYFIN_USER_ID"
      ],
      "profile_manifest_paths": {
        "full": [
          "k8s/unpackerr.yaml"
        ],
        "power-user": [
          "k8s/unpackerr.yaml"
        ]
      },
      "component_enable_manifest_paths": [
        "k8s/unpackerr.yaml"
      ],
      "base_manifest_paths": [
        "k8s/namespace.yaml",
        "k8s/hardening.yaml",
        "k8s/secrets.example.yaml",
        "k8s/storage-pvc.yaml",
        "k8s/core.yaml",
        "k8s/ingress-traefik.yaml",
        "k8s/scale-policy.yaml"
      ],
      "profile_scale_to_zero_apps": {
        "public-demo": [
          "qbittorrent",
          "sonarr",
          "radarr",
          "lidarr",
          "readarr",
          "bazarr",
          "sabnzbd"
        ]
      },
      "profile_tls": {
        "power-user": {
          "secret_name": "media-stack-tls",
          "hosts": [
            "homepage.local",
            "jellyfin.local",
            "jellyseerr.local",
            "sonarr.local",
            "radarr.local",
            "lidarr.local",
            "readarr.local",
            "bazarr.local",
            "prowlarr.local",
            "qbittorrent.local",
            "sabnzbd.local",
            "maintainerr.local",
            "tautulli.local"
          ]
        }
      }
    },
    "microk8s_reconcile": {
      "phase_plan": [
        {
          "phase_name": "Apply core manifests",
          "event": "RECONCILE",
          "handler": "apply_base_kustomize"
        },
        {
          "phase_name": "Apply optional manifests",
          "event": "RECONCILE",
          "handler": "apply_optional_manifests",
          "when": {
            "any_of": [
              {
                "var": "flags.include_optional",
                "equals": true
              },
              {
                "var": "state.optional_deployments_present",
                "equals": true
              }
            ]
          }
        },
        {
          "phase_name": "Apply conditional manifests",
          "event": "RECONCILE",
          "handler": "apply_conditional_manifests"
        },
        {
          "phase_name": "Restart deployments",
          "event": "RECONCILE",
          "handler": "restart_all_deployments"
        },
        {
          "phase_name": "Wait for deployment rollouts",
          "event": "CHECK_STATUS",
          "handler": "wait_all_rollouts"
        },
        {
          "phase_name": "Print pod state",
          "event": "REPORT",
          "handler": "print_pod_state"
        },
        {
          "phase_name": "Fail if any rollout is unhealthy",
          "event": "ENSURE",
          "handler": "fail_if_rollout_failed"
        }
      ],
      "optional_deployments": [
        "homepage",
        "plex",
        "tautulli",
        "sabnzbd",
        "flaresolverr"
      ],
      "optional_manifest_paths": [
        "k8s/optional.yaml"
      ],
      "conditional_manifests": [
        {
          "deployment": "unpackerr",
          "manifest_path": "k8s/unpackerr.yaml",
          "message": "Applying unpackerr manifest (replicas default to 0 in repo)."
        }
      ]
    }
  },
  "app_auth": {
    "enabled": true,
    "method": "Forms",
    "required": "DisabledForLocalAddresses",
    "fail_on_error": false,
    "username_env": "STACK_ADMIN_USERNAME",
    "password_env": "STACK_ADMIN_PASSWORD",
    "include": [],
    "include_note": "Empty = all services with password_api_path in registry"
  }
}
