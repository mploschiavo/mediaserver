{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://media-stack.local/schemas/media-stack.bootstrap.profile.schema.json",
  "title": "Media Stack Bootstrap Profile (v1)",
  "description": "Canonical bootstrap profile for platform + install tier + routing/auth posture.",
  "type": "object",
  "required": ["schema_version", "kind", "metadata", "resources", "install_profile"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "enum": ["media_stack_profile", "media_stack_config"]
    },
    "metadata": {
      "type": "object",
      "required": ["name", "platform", "purpose"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "platform": {
          "type": "string",
          "enum": ["k8s", "kubernetes", "microk8s", "compose", "dockercompose", "docker-compose"]
        },
        "purpose": { "type": "string", "enum": ["dev", "test", "prod", "standard"] },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "required": ["disk_space_gb", "network_cidr"],
      "properties": {
        "disk_space_gb": {
          "oneOf": [
            { "type": "integer", "minimum": 20 },
            { "type": "string", "minLength": 1 }
          ]
        },
        "network_cidr": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "install_profile": {
      "type": "string",
      "enum": ["minimal", "standard", "full"]
    },
    "apps": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "bootstrap": {
      "type": "object",
      "properties": {
        "preconfigure_apps": { "type": "boolean" },
        "preconfigure_api_keys": { "type": "boolean" },
        "apply_initial_preferences": { "type": "boolean" },
        "auto_download_content": { "type": "boolean" },
        "trigger_indexer_sync": { "type": "boolean" },
        "refresh_health_after_setup": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "technology_bindings": {
      "type": "object",
      "description": "Role-to-technology mappings. Change these to swap implementations.",
      "properties": {
        "torrent_client": { "type": "string" },
        "usenet_client": { "type": "string" },
        "media_server": { "type": "string" },
        "request_manager": { "type": "string" },
        "indexer_manager": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "routing": {
      "type": "object",
      "properties": {
        "internet_exposed": { "type": "boolean" },
        "strategy": {
          "type": "string",
          "enum": ["subdomain", "path-prefix", "hybrid", "local", "path_prefix", "pathprefix"]
        },
        "provider": { "type": "string" },
        "base_domain": { "type": "string", "minLength": 1 },
        "stack_subdomain": { "type": "string", "minLength": 1 },
        "gateway_host": { "type": "string" },
        "gateway_port": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 65535 },
            { "type": "string", "pattern": "^[0-9]{1,5}$" }
          ]
        },
        "app_path_prefix": { "type": "string" },
        "media_server_service_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "direct_hosts": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "provider": { "type": "string" },
        "middleware": { "type": "string" }
      },
      "additionalProperties": false
    },
    "app_auth": {
      "type": "object",
      "description": "Service-level authentication — set passwords on Sonarr, Radarr, etc.",
      "properties": {
        "enabled": { "type": "boolean" },
        "method": { "type": "string" },
        "required": { "type": "string" },
        "fail_on_error": { "type": "boolean" },
        "username_env": { "type": "string" },
        "password_env": { "type": "string" },
        "include": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "chaos": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "duration_minutes": { "type": "integer", "minimum": 1, "maximum": 120 },
        "interval_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
        "actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["restart_container", "pause_container", "network_disconnect"]
          }
        }
      },
      "additionalProperties": false
    },
    "live_tv_defaults": {
      "type": "object",
      "properties": {
        "tuner_url": { "type": "string" },
        "tuner_urls": { "type": "array", "items": { "type": "string" } },
        "guide_url": { "type": "string" },
        "guide_urls": { "type": "array", "items": { "type": "string" } },
        "default_program_icon_url": { "type": "string" },
        "default_program_icon_urls": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
