{
  "id": "tv-delete-watched-after-30d",
  "enabled": true,
  "description": "Delete watched TV media that was added at least 30 days ago.",
  "rule": {
    "name": "Delete Watched TV After 30 Days",
    "libraries": [
      "TV Shows"
    ],
    "conditions": {
      "watched": true,
      "added_days_ago_gte": 30
    },
    "actions": {
      "delete_item": true,
      "arr_delete_or_unmonitor": "delete"
    }
  }
}
