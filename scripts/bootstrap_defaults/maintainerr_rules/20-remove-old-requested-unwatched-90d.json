{
  "id": "remove-old-requested-unwatched-90d",
  "enabled": true,
  "description": "Delete old requested content that remains unwatched after 90 days.",
  "rule": {
    "name": "Remove Old Requested Unwatched Content",
    "libraries": [
      "Movies",
      "TV Shows",
      "Music",
      "Books"
    ],
    "conditions": {
      "requested_via": "jellyseerr",
      "watched": false,
      "requested_days_ago_gte": 90
    },
    "actions": {
      "delete_item": true,
      "arr_delete_or_unmonitor": "delete",
      "remove_request_record": true
    }
  }
}
