{
  "precheck_steps": {
    "steps": [
      {
        "event": "VALIDATE",
        "handler": "ensure_prowlarr_ready",
        "args": ["cfg", "prowlarr_url", "prowlarr_key", "app_auth_cfg", "wait_timeout"],
        "enabled_when_attr": "prowlarr_url"
      },
      {
        "event": "ENSURE",
        "handler": "ensure_maintainerr_policy",
        "args": ["cfg", "config_root"],
        "enabled_attr": "configure_maintainerr_policy",
        "required_attr": "maintainerr_required",
        "warning_message": "[WARN] Maintainerr policy: automation skipped. Set maintainerr.required=true to fail the bootstrap instead."
      }
    ]
  },
  "post_servarr_pre_media_steps": {
    "steps": [
      {
        "event": "ENSURE",
        "handler": "ensure_bazarr_arr_integration",
        "args": ["cfg", "config_root", "arr_apps_raw", "app_keys", "wait_timeout"],
        "enabled_attr": "configure_bazarr_integration",
        "required_attr": "bazarr_required",
        "warning_message": "[WARN] Bazarr: integration bootstrap skipped. Set bazarr.required=true to fail the bootstrap instead."
      },
      {
        "event": "RUN",
        "handler": "configure_jellyseerr",
        "args": ["cfg", "arr_apps_raw", "app_keys", "config_root", "wait_timeout"],
        "enabled_attr": "configure_jellyseerr_services",
        "required_attr": "jellyseerr_required",
        "warning_message": "[WARN] Jellyseerr: automation skipped. Set jellyseerr.required=true to fail the bootstrap instead."
      },
      {
        "event": "ENSURE",
        "handler": "ensure_maintainerr_integrations",
        "args": ["cfg", "config_root", "arr_apps_raw", "wait_timeout"],
        "enabled_attr": "configure_maintainerr_integrations",
        "required_attr": "maintainerr_integrations_required",
        "warning_message": "[WARN] Maintainerr integrations: automation skipped. Set maintainerr.integrations.required=true to fail the bootstrap instead."
      }
    ]
  },
  "post_servarr_post_media_steps": {
    "steps": [
      {
        "event": "ENSURE",
        "handler": "enforce_disk_guardrails",
        "args": [
          "cfg",
          "config_root",
          "torrent_client_cfg",
          "torrent_client_username",
          "torrent_client_password"
        ],
        "enabled_attr": "configure_disk_guardrails",
        "required_attr": "disk_guardrails_required",
        "warning_message": "[WARN] Disk guardrails: automation skipped. Set disk_guardrails.required=true to fail the bootstrap instead."
      },
      {
        "event": "RUN",
        "handler": "run_media_hygiene",
        "args": [
          "cfg",
          "config_root",
          "arr_apps_raw",
          "app_keys",
          "torrent_client_cfg",
          "torrent_client_username",
          "torrent_client_password"
        ],
        "enabled_attr": "configure_media_hygiene",
        "required_attr": "media_hygiene_required",
        "warning_message": "[WARN] Media hygiene: automation skipped. Set media_hygiene.required=true to fail the bootstrap instead."
      },
      {
        "event": "ENSURE",
        "handler": "ensure_homepage_services_config",
        "args": ["cfg", "config_root"],
        "enabled_attr": "configure_homepage_services",
        "required_attr": "homepage_required",
        "warning_message": "[WARN] Homepage: config-as-code bootstrap skipped. Set homepage.required=true to fail the bootstrap instead."
      }
    ]
  },
  "indexer_steps": {
    "steps": [
      {
        "event": "RUN",
        "handler": "run_prowlarr_indexer_pipeline",
        "enabled_when_attr": "prowlarr_url",
        "args": [
          "cfg",
          "prowlarr_url",
          "prowlarr_key",
          "wait_timeout",
          "prowlarr_indexers",
          "auto_indexers",
          "trigger_sync",
          "arr_apps_raw",
          "app_keys"
        ]
      }
    ]
  }
}
